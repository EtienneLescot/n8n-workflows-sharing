      "parameters": {
        "schemaType": "manual",
        "autoFix": true,
        "jsonSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"recommendedTechnician\": { \"type\": \"string\" },\n    \"recommendedStart\": { \"type\": \"string\" },\n    \"recommendedEnd\": { \"type\": \"string\" },\n    \"travelMinutes\": { \"type\": \"number\" },\n    \"ruleBreak\": { \"type\": \"boolean\" },\n    \"ruleBreakReason\": { \"type\": \"string\" },\n    \"dispatchSummary\": { \"type\": \"string\" }\n  },\n  \"required\": [\"recommendedTechnician\", \"recommendedStart\", \"dispatchSummary\"]\n}"
      }
