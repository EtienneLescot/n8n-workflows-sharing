        "jsonSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"serviceType\": { \"type\": \"string\" },\n    \"urgency\": { \"type\": \"string\" },\n    \"confidenceLevel\": { \"type\": \"number\" },\n    \"emergencyFlag\": { \"type\": \"boolean\" },\n    \"nextAction\": {\n      \"type\": \"string\",\n      \"enum\": [\n        \"ask_follow_up\",\n        \"prepare_quote\",\n        \"recommend_site_visit\",\n        \"schedule_dispatch\",\n        \"manual_review\",\n        \"emergency_escalation\",\n        \"invoice_and_follow_up\"\n      ]\n    },\n    \"approvalRequired\": { \"type\": \"boolean\" },\n    \"approvalReason\": { \"type\": \"string\" },\n    \"customerMessageBrief\": { \"type\": \"string\" },\n    \"internalSummary\": { \"type\": \"string\" },\n    \"requiredFollowUpQuestions\": {\n      \"type\": \"array\",\n      \"items\": { \"type\": \"string\" }\n    },\n    \"quoteIntent\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"remoteQuoteFeasible\": { \"type\": \"boolean\" },\n        \"estimatedRangeLow\": { \"type\": \"number\" },\n        \"estimatedRangeHigh\": { \"type\": \"number\" },\n        \"scopeSummary\": { \"type\": \"string\" }\n      }\n    },\n    \"scheduleIntent\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"preferredWindow\": { \"type\": \"string\" },\n        \"requiredSkills\": { \"type\": \"array\", \"items\": { \"type\": \"string\" } },\n        \"recommendedTechnician\": { \"type\": \"string\" },\n        \"recommendedStart\": { \"type\": \"string\" }\n      }\n    },\n    \"invoiceIntent\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"invoiceNow\": { \"type\": \"boolean\" },\n        \"amount\": { \"type\": \"number\" },\n        \"lineItems\": { \"type\": \"array\", \"items\": { \"type\": \"object\" } }\n      }\n    },\n    \"reviewQueuePayload\": { \"type\": \"object\" }\n  },\n  \"required\": [\"nextAction\", \"approvalRequired\", \"custome