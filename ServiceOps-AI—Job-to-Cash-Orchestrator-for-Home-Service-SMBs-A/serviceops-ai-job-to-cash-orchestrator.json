      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "\nconst job = $json.jobRequest || {};\nconst nextAction = $json.nextAction || 'manual_review';\nconst highValueQuote = Number($json.quoteIntent?.estimatedRangeHigh || job.estimatedValue || 0) >= Number($env.SERVICEOPS_HIGH_VALUE_QUOTE_THRESHOLD || 750);\nconst highValueInvoice = Number($json.invoiceIntent?.amount || 0) >= Number($env.SERVICEOPS_HIGH_VALUE_INVOICE_THRESHOLD || 1000);\nconst emergencyFlag = Boolean($json.emergencyFlag || job.emergencyFlag);\nconst lowConfidence = Number($json.confidenceLevel || job.confidenceLevel || 0) < Number($env.SERVICEOPS_LOW_CONFIDENCE_THRESHOLD || 0.72);\nconst approvalRequired = Boolean($json.approvalRequired || emergencyFlag || highValueQuote || highValueInvoice || lowConfidence);\nconst approvalReason = $json.approvalReason || (\n  emergencyFlag ? 'Emergency dispatch requires approval' :\n  highValueQuote ? 'High-value quote requires approval' :\n  highValueInvoice ? 'High-value invoice requires approval' :\n  lowConfidence ? 'Low-confidence decision requires review' : ''\n);\n\nreturn {\n  json: {\n    ...$json,\n    nextAction,\n    approvalRequired,\n    approvalReason,\n    serviceType: $json.serviceType || job.serviceType || 'unclassified',\n    urgency: $json.urgency || job.urgency || 'unknown',\n  },\n};"
      }
    },
