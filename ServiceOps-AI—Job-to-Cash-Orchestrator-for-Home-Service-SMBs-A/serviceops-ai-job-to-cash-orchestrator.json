    {
      "id": "90dd23e1-4927-4e2d-96b0-a8db6aed7c36",
      "name": "Normalize Inbound Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -940,
        100
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "\nconst input = $json;\nconst origin = input.headers?.['x-serviceops-origin'] || input.origin || input.source || input.channel || 'unknown';\nconst body = input.body ?? input;\nconst now = new Date().toISOString();\nconst eventType = body.eventType || (origin === 'job_completed' ? 'job_completed' : 'new_request');\nconst customer = {\n  name: body.customerName || body.fromName || body.name || body.customer?.name || '',\n  email: body.customerEmail || body.email || body.customer?.email || '',\n  phone: body.customerPhone || body.phone || body.from || body.customer?.phone || '',\n  preferredChannel: body.preferredChannel || (body.customer?.email ? 'email' : 'whatsapp'),\n};\nconst location = {\n  address1: body.address || body.serviceAddress || body.location?.address1 || '',\n  city: body.city || body.location?.city || '',\n  region: body.state || body.region || body.location?.region || '',\n  postalCode: body.zip || body.postalCode || body.location?.postalCode || '',\n  notes: body.locationNotes || body.accessNotes || '',\n};\nconst summary = body.issueSummary || body.summary || body.subject || body.title || body.transcriptSummary || '';\nconst details = body.issueDetails || body.description || body.transcript || body.message || body.text || '';\nconst customerKey = [customer.email, customer.phone].filter(Boolean).join('|') || (customer.name || 'anonymous');\nconst fingerprintSeed = [eventType, origin, customerKey, location.address1, summary, details].join('|').toLowerCase();\nconst fingerprint = Buffer.from(fingerprintSeed).toString('base64').slice(0, 48);\n\nreturn {\n  json: {\n    workflowTemplate: 'ServiceOps AI',\n    eventType,\n    requestOrigin: origin,\n    requestReceivedAt: now,\n    jobRequest: {\n      requestOrigin: origin,\n      customer,\n      serviceLocation: location,\n      serviceType: body.serviceType || '',\n      issueSummary: summary,\n      issueDetails: details,\n      urgency: body.urgency || 'unknown',\n      emergencyFlag: Boolean(body.emergencyFlag || false),\n      confidenceLevel: Number(body.confidenceLevel || 0.25),\n      requiredFollowUpQuestions: Array.isArray(body.followUpQuestions) ? body.followUpQuestions : [],\n      serviceAreaValidation: 'unknown',\n      estimatedValue: Number(body.estimatedValue || 0),\n      remoteQuoteFeasibility: body.remoteQuoteFeasibility || 'unknown',\n      requiredSkills: Array.isArray(body.requiredSkills) ? body.requiredSkills : [],\n      preferredTimeWindow: body.preferredTimeWindow || '',\n      nextRecommendedAction: eventType === 'job_completed' ? 'invoice_and_follow_up' : 'triage',\n      approvalRequirement: 'pending',\n      assignedTechnician: body.assignedTechnician || '',\n      scheduledTime: body.scheduledTime || '',\n      quoteReference: body.quoteReference || '',\n      invoiceReference: body.invoiceReference || '',\n      paymentLink: body.paymentLink || '',\n      status: body.status || (eventType === 'job_completed' ? 'job_completed' : 'new'),\n      auditTrail: [{ at: now, actor: 'workflow', action: 'normalized_intake', origin }],\n    },\n    idempotencyKey: fingerprint,\n    rateLimitBucket: customer.phone || customer.email || location.postalCode || 'default',\n    rawPayload: body,\n  },\n};"
      }
    },
