    {
      "parameters": {
        "operation": "get",
        "dataTableId": {
          "__rl": true,
          "mode": "list",
          "value": ""
        },
        "matchType": "allConditions",
        "filters": {
          "conditions": [
            {
              "keyName": "detected_date",
              "condition": "gte",
              "keyValue": "={{ $now.minus({ days: 30 }).toISO() }}"
