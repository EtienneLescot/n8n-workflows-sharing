      "id": "73a8b6b9-7fb8-4e33-82ea-b02949264c44",
      "name": "Daily 7 AM Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [
        240,
        400
      ]
    },
    {
      "parameters": {
        "messages": {
          "message": [
            {
              "content": "<__PLACEHOLDER_VALUE__Enter your competitors (e.g., \"Shopify, WooCommerce, BigCommerce\") and your industry (e.g., \"e-commerce platforms\")__>"
            }
          ]
        },
        "options": {
          "maxTokens": 2000,
          "returnRelatedQuestions": true,
          "searchRecency": "day"
        },
        "requestOptions": {}
      },
      "id": "ef34269e-cb40-4618-af94-dd97a9bbd208",
      "name": "Fetch Competitor Intelligence",
      "type": "n8n-nodes-base.perplexity",
      "typeVersion": 1,
      "position": [
        464,
        304
      ]
    },
    {
      "parameters": {},
      "id": "8a5efac4-0c29-467f-8466-c2dbb146c369",
      "name": "Combine Intelligence Sources",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [
        688,
        400
      ]
    },
    {
      "parameters": {
        "url": "<__PLACEHOLDER_VALUE__Enter competitor pricing page URL (e.g., https://www.shopify.com/pricing)__>",
        "options": {
          "response": {
            "response": {
              "responseFormat": "text",
              "outputPropertyName": "pricingHtml"
            }
          }
        }
      },
      "id": "f8805e95-69bb-4a3a-a150-190c53ef3dd3",
      "name": "Fetch Competitor Pricing",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        464,
        496
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze this competitive intelligence data and extract structured insights:\n\n{{ $json.choices?.[0]?.message?.content ?? $json.pricingHtml }}\n\nFor each significant development:\n1. Identify the competitor\n2. Categorize as: product_launch, pricing_change, partnership, marketing_campaign, or other\n3. Assign priority: low, medium, high, critical\n4. Calculate impact_score (0-100) based on potential business impact\n5. Provide a concise summary\n6. Explain business implications\n7. Recommend 2-3 specific actions\n8. Determine sentiment: opportunity, threat, or neutral\n9. Note any pricing changes with details",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a competitive intelligence analyst for e-commerce businesses. Analyze competitor developments with a focus on actionable insights, business impact, and strategic recommendations. Be concise but thorough.",
          "maxIterations": 5
        }
      },
      "id": "ad9fb092-dff0-4abb-8b1d-7eb1343da7cf",
      "name": "AI Intelligence Analyzer",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        912,
        400
      ]
    },
    {
      "parameters": {
        "model": {
          "__rl": true,
          "mode": "list",
          "value": "gpt-5-mini"
        },
        "builtInTools": {},
        "options": {
          "maxTokens": 1500,
          "temperature": 0.2
        }
      },
      "id": "668b99ee-ad90-4886-8dd9-3479e78e28e1",
      "name": "OpenAI GPT-5 Mini",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.3,
      "position": [
        928,
        624
      ],
      "credentials": {
        "openAiApi": {
          "id": "3tpHjeLbkX5PIuNM",
          "name": "n8n free OpenAI API credits"
        }
      }
    },
    {
      "parameters": {
        "jsonSchemaExample": {
          "competitor": "Shopify",
          "category": "product_launch",
          "priority": "high",
          "impact_score": 85,
          "summary": "Brief summary of the development",
          "business_implications": "What this means for your business",
          "recommended_actions": [
            "Action 1",
            "Action 2"
          ],
          "sentiment": "threat",
          "pricing_change": false,
          "pricing_details": null
        }
      },
      "id": "8fdc180b-d2f8-4bf1-97d9-643042f818ef",
      "name": "Intelligence Schema",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        1056,
        624
      ]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.output.priority }}",
                    "rightValue": "critical",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "Critical"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.output.priority }}",
                    "rightValue": "high",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "High"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.output.impact_score }}",
                    "rightValue": 50,
                    "operator": {
                      "type": "number",
                      "operation": "gt"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "Medium"
            }
          ]
        },
        "options": {
          "fallbackOutput": "none"
        }
      },
      "id": "e1f61e2e-0032-4852-a8ca-db851ddd5bd4",
      "name": "Route by Priority",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.4,
      "position": [
        1264,
        384
      ]
    },
    {
      "parameters": {
        "authentication": "oAuth2",
        "select": "channel",
        "channelId": {
          "__rl": true,
          "mode": "list",
          "value": ""
        },
        "messageType": "block",
        "blocksUi": "=[\n  {\n    \"type\": \"header\",\n    \"text\": {\n      \"type\": \"plain_text\",\n      \"text\": \"🚨 {{ $json.output.priority === \\\"critical\\\" ? \\\"CRITICAL\\\" : \\\"HIGH PRIORITY\\\" }} Alert: {{ $json.output.competitor }}\"\n    }\n  },\n  {\n    \"type\": \"section\",\n    \"fields\": [\n      {\n        \"type\": \"mrkdwn\",\n        \"text\": \"*Category:*\\n{{ $json.output.category }}\"\n      },\n      {\n        \"type\": \"mrkdwn\",\n        \"text\": \"*Impact Score:*\\n{{ $json.output.impact_score }}/100\"\n      },\n      {\n        \"type\": \"mrkdwn\",\n        \"text\": \"*Sentiment:*\\n{{ $json.output.sentiment }}\"\n      }\n    ]\n  },\n  {\n    \"type\": \"section\",\n    \"text\": {\n      \"type\": \"mrkdwn\",\n      \"text\": \"*Summary:*\\n{{ $json.output.summary }}\"\n    }\n  },\n  {\n    \"type\": \"section\",\n    \"text\": {\n      \"type\": \"mrkdwn\",\n      \"text\": \"*Business Implications:*\\n{{ $json.output.business_implications }}\"\n    }\n  },\n  {\n    \"type\": \"section\",\n    \"text\": {\n      \"type\": \"mrkdwn\",\n      \"text\": \"*Recommended Actions:*\\n{{ $json.output.recommended_actions.map((action, i) => `${i + 1}. ${action}`).join(\\\"\\\\n\\\") }}\"\n    }\n  }\n]",
        "text": "=🚨 {{ $json.output.priority === \"critical\" ? \"CRITICAL\" : \"HIGH PRIORITY\" }} Competitive Intelligence Alert",
        "otherOptions": {}
      },
      "id": "0d25ff9d-9bed-468c-a8b8-3e1d4a155ce9",
      "name": "Urgent Slack Alert",
