    {
      "parameters": {
        "sendTo": "<__PLACEHOLDER_VALUE__Enter recipient email (e.g., ceo@yourcompany.com)__>",
        "subject": "=Daily Competitive Intelligence Digest - {{ $now.toFormat(\"MMMM d, yyyy\") }}",
        "message": "=<html>\n<head><style>\n  body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }\n  .header { background: #4A90E2; color: white; padding: 20px; text-align: center; }\n  .summary { background: #f4f4f4; padding: 15px; margin: 20px 0; border-left: 4px solid #4A90E2; }\n  .competitor { margin: 20px 0; padding: 15px; border: 1px solid #ddd; border-radius: 5px; }\n  .metric { display: inline-block; margin: 10px 20px 10px 0; }\n  .metric-value { font-size: 24px; font-weight: bold; color: #4A90E2; }\n  .metric-label { font-size: 12px; color: #666; }\n</style></head>\n<body>\n  <div class=\"header\">\n    <h1>📊 Daily Competitive Intelligence Digest</h1>\n    <p>{{ $now.toFormat(\"MMMM d, yyyy\") }}</p>\n  </div>\n  \n  <div class=\"summary\">\n    <h2>Executive Summary</h2>\n    <p>Monitoring {{ $(\"Analyze Trends\").all().length }} competitors over the past 30 days.</p>\n    <div class=\"metric\">\n      <div class=\"metric-value\">{{ $(\"Analyze Trends\").all().reduce((sum, item) => sum + item.json.count_competitor, 0) }}</div>\n      <div class=\"metric-label\">Total Developments</div>\n    </div>\n    <div class=\"metric\">\n      <div class=\"metric-value\">{{ Math.round($(\"Analyze Trends\").all().reduce((sum, item) => sum + item.json.average_impact_score, 0) / $(\"Analyze Trends\").all().length) }}</div>\n      <div class=\"metric-label\">Avg Impact Score</div>\n    </div>\n  </div>\n  \n  <h2>Competitor Activity (Last 30 Days)</h2>\n  {{ $(\"Sort by Activity\").all().map(item => `\n    <div class=\"competitor\">\n      <h3>${item.json.competitor}</h3>\n      <p><strong>Developments:</strong> ${item.json.count_competitor} | <strong>Avg Impact:</strong> ${Math.round(item.json.average_impact_score)}/100 | <strong>Categories:</strong> ${item.json.countUnique_category}</p>\n    </div>\n  `).join(\"\") }}\n  \n  <div style=\"margin-top: 30px; padding: 15px; background: #f9f9f9; border-top: 2px solid #4A90E2;\">\n    <p style=\"font-size: 12px; color: #666;\">This report was automatically generated by your n8n Competitive Intelligence workflow. High-priority alerts were sent to Slack in real-time.</p>\n  </div>\n</body>\n</html>",
        "options": {
          "appendAttribution": false
        }
      },
