    {
      "parameters": {
        "operation": "upsert",
        "dataTableId": {
          "__rl": true,
          "mode": "list",
          "value": ""
        },
        "matchType": "allConditions",
        "filters": {
          "conditions": [
            {
              "keyName": "competitor",
              "keyValue": "={{ $('AI Intelligence Analyzer').item.json.output.competitor }}"
            },
            {
              "keyName": "summary",
              "keyValue": "={{ $('AI Intelligence Analyzer').item.json.output.summary }}"
            }
          ]
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "competitor": "={{ $('AI Intelligence Analyzer').item.json.output.competitor }}",
            "category": "={{ $('AI Intelligence Analyzer').item.json.output.category }}",
            "priority": "={{ $('AI Intelligence Analyzer').item.json.output.priority }}",
            "impact_score": "={{ $('AI Intelligence Analyzer').item.json.output.impact_score }}",
            "summary": "={{ $('AI Intelligence Analyzer').item.json.output.summary }}",
            "business_implications": "={{ $('AI Intelligence Analyzer').item.json.output.business_implications }}",
            "recommended_actions": "={{ JSON.stringify($('AI Intelligence Analyzer').item.json.output.recommended_actions) }}",
            "sentiment": "={{ $('AI Intelligence Analyzer').item.json.output.sentiment }}",
            "pricing_change": "={{ $('AI Intelligence Analyzer').item.json.output.pricing_change }}",
            "pricing_details": "={{ $('AI Intelligence Analyzer').item.json.output.pricing_details }}",
            "detected_date": "={{ $now.toISO() }}"
          }
        },
        "options": {}
      },
      "id": "0e92becb-fcf6-4053-97ea-42e5c6b3ed76",
