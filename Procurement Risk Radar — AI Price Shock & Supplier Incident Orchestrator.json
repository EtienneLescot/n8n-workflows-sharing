    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const pdfText = $json.text ?? $json.data ?? '';\nconst context = {\n  vendorName: $json.vendorName,\n  sku: $json.sku,\n  itemName: $json.itemName,\n  currentUnitCost: $json.currentUnitCost,\n  quotedUnitCost: $json.quotedUnitCost,\n  currentLeadTimeDays: $json.currentLeadTimeDays,\n  quotedLeadTimeDays: $json.quotedLeadTimeDays,\n  currentMoq: $json.currentMoq,\n  quotedMoq: $json.quotedMoq,\n  effectiveDate: $json.effectiveDate,\n};\nreturn {\n  json: {\n    ...$json,\n    extractionText: [\n      'Normalize this supplier update into structured procurement change data.',\n      'Known context: ' + JSON.stringify(context),\n      'Supplier message:',\n      $json.text || '',\n      'PDF text:',\n      pdfText,\n    ].join('\n\n'),\n  },\n};"
      },
      "id": "1fa4cda4-419b-4de8-a7b4-33ceadfac98b",
      "name": "Build Extraction Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1408,
        320
      ]
    },
    {
      "parameters": {
        "text": "={{ $json.extractionText }}",
        "schemaType": "manual",
        "inputSchema": "={\n  \"type\": \"object\",\n  \"properties\": {\n    \"changeType\": { \"type\": \"string\" },\n    \"supplierName\": { \"type\": \"string\" },\n    \"sku\": { \"type\": \"string\" },\n    \"priceDeltaPct\": { \"type\": \"number\" },\n    \"leadTimeDeltaDays\": { \"type\": \"number\" },\n    \"moqDelta\": { \"type\": \"number\" },\n    \"confidence\": { \"type\": \"number\" },\n    \"reason\": { \"type\": \"string\" },\n    \"recommendedAction\": { \"type\": \"string\" }\n  },\n  \"required\": [\"changeType\", \"supplierName\", \"sku\", \"confidence\"]\n}",
        "options": {}
      },
      "id": "b20cd420-ac04-402c-885e-3f04a0583a50",
      "name": "Supplier Change Extractor",
      "type": "@n8n/n8n-nodes-langchain.informationExtractor",
      "typeVersion": 1.2,
      "position": [
        1632,
        320
      ]
