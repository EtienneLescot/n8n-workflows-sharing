        "options": {}
      },
      "id": "92ab8808-ab21-4f37-9b67-9c143eade386",
      "name": "Extraction Llm",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.3,
      "position": [
        1704,
        544
      ],
      "credentials": {
        "openAiApi": {
          "id": "OPENAI_CREDENTIAL_ID",
          "name": "OpenAI"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const e = $json;\nconst quotedUnitCost = Number(e.quotedUnitCost ?? e.currentUnitCost ?? 0);\nconst currentUnitCost = Number(e.currentUnitCost ?? 0);\nconst monthlyVolume = Number(e.monthlyVolume ?? 0);\nconst priceDeltaPct = e.priceDeltaPct ?? (currentUnitCost > 0 ? Number((((quotedUnitCost - currentUnitCost) / currentUnitCost) * 100).toFixed(2)) : 0);\nconst leadTimeDeltaDays = e.leadTimeDeltaDays ?? (Number(e.quotedLeadTimeDays ?? 0) - Number(e.currentLeadTimeDays ?? 0));\nconst moqDelta = e.moqDelta ?? (Number(e.quotedMoq ?? 0) - Number(e.currentMoq ?? 0));\nconst stockoutRisk = e.daysOfCover <= 7 ? 30 : e.daysOfCover <= 14 ? 18 : 6;\nconst concentrationRisk = e.fallbackSuppliers === 0 ? 25 : e.fallbackSuppliers === 1 ? 16 : 6;\nconst strategicRisk = e.strategicItem ? 14 : 4;\nconst priceRisk = priceDeltaPct >= 12 ? 28 : priceDeltaPct >= 7 ? 18 : priceDeltaPct >= 3 ? 10 : 2;\nconst leadTimeRisk = leadTimeDeltaDays >= 14 ? 22 : leadTimeDeltaDays >= 7 ? 14 : leadTimeDeltaDays > 0 ? 8 : 0;\nconst moqRisk = moqDelta >= 500 ? 12 : moqDelta >= 100 ? 7 : moqDelta > 0 ? 3 : 0;\nconst estimatedMonthlyMarginImpact = Number(((quotedUnitCost - currentUnitCost) * monthlyVolume).toFixed(2));\nlet riskScore = priceRisk + leadTimeRisk + moqRisk + stockoutRisk + concentrationRisk + strategicRisk;\nriskScore = Math.max(0, Math.min(100, riskScore));\nlet riskLane = 'low';\nif (riskScore >= 75 || estimatedMonthlyMarginImpact >= 5000 || stockoutRisk >= 30) riskLane = 'critical';\nelse if (riskScore >= 45 || estimatedMonthlyMarginImpact >= 1500) riskLane = 'review';\nconst incidentId = 'PRI-' + Date.now() + '-' + String(e.sku || 'SKU').replace(/[^A-Z0-9]/gi, '').slice(0, 6).toUpperCase();\nreturn {\n  json: {\n    ...e,\n    priceDeltaPct,\n    leadTimeDeltaDays,\n    moqDelta,\n    estimatedMonthlyMarginImpact,\n    riskScore,\n    riskLane,\n    incidentId,\n    buyerRecommendation: riskLane === 'critical'\n      ? 'Escalate immediately, freeze affected PO changes, request backup quote.'\n      : riskLane === 'review'\n      ? 'Open approval task and compare fallback supplier options within SLA.'\n      : 'Log for digest and monitor next supplier update.',\n    decisionSlaHours: riskLane === 'critical' ? 2 : riskLane === 'review' ? 12 : 48,\n  },\n};"
      },
