    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const body = $json.body ?? $json;\nconst sourceType = $json.headers ? 'supplier_portal_webhook' : ($json.labelIds ? 'gmail_supplier_email' : 'scheduled_contract_sweep');\nconst attachments = $json.attachments ?? body.attachments ?? [];\nconst firstAttachment = attachments[0] ?? {};\nconst subject = $json.subject ?? body.subject ?? body.alertType ?? 'Supplier update';\nconst textParts = [\n  $json.textPlain,\n  $json.snippet,\n  body.message,\n  body.summary,\n  body.notes,\n  JSON.stringify(body),\n].filter(Boolean);\nconst text = textParts.join('\n\n');\nconst vendorName = body.vendorName ?? body.supplierName ?? $json.from?.name ?? $json.from?.email ?? 'Unknown supplier';\nconst sku = body.sku ?? body.itemSku ?? body.productCode ?? 'unknown-sku';\nconst stockOnHand = Number(body.stockOnHand ?? body.inventoryOnHand ?? body.qtyOnHand ?? 0);\nconst avgDailyDemand = Number(body.avgDailyDemand ?? body.salesVelocity ?? 3);\nconst daysOfCover = avgDailyDemand > 0 ? Number((stockOnHand / avgDailyDemand).toFixed(1)) : 999;\nreturn {\n  json: {\n    sourceType,\n    receivedAt: new Date().toISOString(),\n    vendorName,\n    vendorEmail: $json.from?.email ?? body.vendorEmail ?? 'vendor@example.com',\n    subject,\n    text,\n    sku,\n    itemName: body.itemName ?? body.productName ?? 'Critical stocked item',\n    currentUnitCost: Number(body.currentUnitCost ?? body.previousUnitCost ?? 42),\n    quotedUnitCost: Number(body.quotedUnitCost ?? body.newUnitCost ?? body.proposedCost ?? 45),\n    currentLeadTimeDays: Number(body.currentLeadTimeDays ?? body.previousLeadTimeDays ?? 14),\n    quotedLeadTimeDays: Number(body.quotedLeadTimeDays ?? body.newLeadTimeDays ?? body.proposedLeadTimeDays ?? 21),\n    currentMoq: Number(body.currentMoq ?? 100),\n    quotedMoq: Number(body.quotedMoq ?? body.newMoq ?? 150),\n    effectiveDate: body.effectiveDate ?? $today.plus({ days: 7 }).toISODate(),\n    stockOnHand,\n    avgDailyDemand,\n    daysOfCover,\n    monthlyVolume: Number(body.monthlyVolume ?? 300),\n    fallbackSuppliers: Number(body.fallbackSuppliers ?? 1),\n    strategicItem: Boolean(body.strategicItem ?? true),\n    onContract: Boolean(body.onContract ?? true),\n    openPoValue: Number(body.openPoValue ?? 12500),\n    binary: {\n      attachmentProperty: Object.keys($binary ?? {})[0] ?? null,\n      attachmentFileName: firstAttachment.filename ?? firstAttachment.fileName ?? null,\n      attachmentMimeType: firstAttachment.mimeType ?? null,\n    },\n  },\n};"
      },
